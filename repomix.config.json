{
    "$schema": "https://repomix.com/schemas/latest/schema.json",
    "input": {
        "maxFileSize": 50000000
    },
    "output": {
        "filePath": "repomix-output-truncated.md",
        "style": "markdown",
        "parsableStyle": false,
        "compress": true,
        "fileSummary": true,
        "directoryStructure": true,
        "files": true,
        "removeComments": true,
        "removeEmptyLines": true,
        "showLineNumbers": false,
        "truncateBase64": false,
        "copyToClipboard": false,
        "includeEmptyDirectories": false,
        "topFilesLength": 5,
        "git": {
            "sortByChanges": true,
            "sortByChangesMaxCommits": 100,
            "includeDiffs": false,
            "includeLogs": false,
            "includeLogsCount": 50
        }
    },
    "include": [
        "src/**/*",
        "projects/**/*",
        "angular.json",
        "package.json",
        "package-lock.json",
        "pnpm-lock.yaml",
        "yarn.lock",
        "tsconfig*.json",
        "karma.conf.js",
        "jest.config.*",
        "eslint.config.*",
        ".eslintrc*",
        ".prettierrc*",
        "proxy.conf*.json",
        "README.md"
    ],
    "ignore": {
        "useGitignore": true,
        "useDotIgnore": true,
        "useDefaultPatterns": true,
        "customPatterns": [
            "**/node_modules/**",
            "**/dist/**",
            "**/coverage/**",
            "**/.angular/**",
            "**/.angular/cache/**",
            "**/out-tsc/**",
            "**/.cache/**",
            "**/tmp/**",
            "**/storybook-static/**",
            "**/*.map",
	     "**/*.css"
        ]
    },
    "security": {
        "enableSecurityCheck": true
    },
    "tokenCount": {
        "encoding": "o200k_base"
    }
}