                <h2 class="text-xl font-bold text-gray-900 break-all">{{ user()?.name }}</h2>
                <p class="text-sm text-gray-500 mt-1 break-all">{{ user()?.email }}</p>

                <!-- Role Badge -->
                <div class="mt-3">
                    @if (user()?.parentId && user()?.parentId !== '-1') {
                    <span
