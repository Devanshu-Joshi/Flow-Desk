                            [ngClass]="isDark ? 'skeleton-shimmer-dark' : 'skeleton-shimmer'"></div>
                        <div class="h-7 w-16 rounded-lg"
                            [ngClass]="isDark ? 'skeleton-shimmer-dark' : 'skeleton-shimmer'"></div>
                    </div>
                </div>
                <div class="flex items-center justify-center py-4">
