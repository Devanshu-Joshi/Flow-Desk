                </div>
                <div class="flex items-center justify-center py-4">
                    <div class="relative">
                        <svg class="w-48 h-48" viewBox="0 0 200 200">
                            <path d="M100,100 L100,20 A80,80 0 0,1 176.1,56.9 Z"
